{
  "name": "bibit-nav-service",
  "version": "1.0.0",
  "description": "Bibit NAV Service - Fetch and serve NAV data from Bibit",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "@hono/node-server": "^1.11.0",
    "@libsql/client": "0.5.0",
    "drizzle-orm": "^0.31.0",
    "node-cron": "^3.0.3",
    "drizzle-kit": "^0.22.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.15.0"
  }
}
